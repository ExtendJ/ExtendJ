/**
 * Inherited equations for the toClass NTAs.
 */
aspect ToClassInheritedEquations {
  eq LambdaExpr.toClass().enclosingLambda() = this;

  eq ExprMethodReference.toClass().targetType() = targetType().functionDescriptor().method.type();
  eq TypeMethodReference.toClass().targetType() = targetType().functionDescriptor().method.type();
  eq      ClassReference.toClass().targetType() = targetType().functionDescriptor().method.type();
}
