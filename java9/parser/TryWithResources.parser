List resources =
    resource_use.a
    {: return new List().add(a); :}
  | resources.a SEMICOLON resource_use.b
    {: return a.add(b); :}
  ;

ResourceUse resource_use =
    IDENTIFIER
    {: return new ResourceUse(new VarAccess(IDENTIFIER)); :}
  |  field_access.a 
    {: return new ResourceUse(new VarAccess(a)); :}
  ;